---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Entreblogs — Novos participantes</title>
    <link>{{ site.url }}</link>
    <atom:link href="{{ site.url }}/feed-entreblogs.xml" rel="self" type="application/rss+xml"/>
    <description>Acompanhe os blogs que estão entrando no Entreblogs</description>
    <language>pt-br</language>
    <lastBuildDate>{{ site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}</lastBuildDate>

    {% assign participantes_ordenados = site.data.participantes | sort: "added" | reverse %}
    {% for blog in participantes_ordenados %}
    <item>
      <title>{{ blog.blog | xml_escape }}</title>
      <link>{{ blog.url | xml_escape }}</link>
      <guid isPermaLink="true">{{ blog.url | xml_escape }}</guid>
      <pubDate>{% if blog.added %}{{ blog.added | date: "%a, %d %b %Y 12:00:00 +0000" }}{% else %}{{ site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}{% endif %}</pubDate>
      <description><![CDATA[
        <p><strong>{{ blog.blog }}</strong> agora faz parte do Entreblogs.</p>
        <p>Visite: <a href="{{ blog.url }}">{{ blog.url }}</a></p>
        {% if blog.feed and blog.feed != "" %}
        <p>Feed RSS: <a href="{{ blog.feed }}">{{ blog.feed }}</a></p>
        {% endif %}
      ]]></description>
    </item>
    {% endfor %}

  </channel>
</rss>
