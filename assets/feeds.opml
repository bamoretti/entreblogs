---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Feeds do Entreblogs</title>
    <dateCreated>{{ site.time | date: "%a, %d %b %Y %H:%M:%S %z" }}</dateCreated>
  </head>
  <body>
    <outline text="Entreblogs" title="Entreblogs">
      {% for blog in site.data.participantes %}
        {% if blog.feed and blog.feed != "" %}
        <outline 
          type="rss" 
          text="{{ blog.blog | xml_escape }}" 
          title="{{ blog.blog | xml_escape }}" 
          xmlUrl="{{ blog.feed | xml_escape }}" 
          htmlUrl="{{ blog.url | xml_escape }}"/>
        {% endif %}
      {% endfor %}
    </outline>
  </body>
</opml>